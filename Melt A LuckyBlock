-- 7 REMOVE NPC (OPTIMIZED LOOP)
--------------------------------------------------
Tabs.Auto:AddButton({
    Title="Remove NPC",
    Callback=function()
        task.spawn(function()
            while true do
                for _,v in ipairs(workspace:GetChildren()) do
                    if v.Name=="NPC" and v:IsA("Model") then
                        if v:FindFirstChild("Humanoid") or v:FindFirstChild("HumanoidRootPart") then
                            v:Destroy()
                        end
                    end
                end
                task.wait(2)
            end
        end)
    end
})

