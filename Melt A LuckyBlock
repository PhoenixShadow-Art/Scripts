}):OnChanged(function(v)
    _G.Rebirth = v
    while _G.Rebirth do
        Event:FireServer("Rebirth")
        task.wait(1)
    end
end)

--------------------------------------------------
-- 9. REMOVE NOTIFICATIONS
--------------------------------------------------
Tabs.Auto:AddButton({
    Title = "Remove Notifications",
    Callback = function()
        local path = LocalPlayer.PlayerGui.MainGui.Buttons
        while true do
            for _,v in pairs(path:GetChildren()) do
                if v.Name == "NotificationTemplate" then
                    v:Destroy()
                end
            end
            task.wait(1)
        end
    end
})

