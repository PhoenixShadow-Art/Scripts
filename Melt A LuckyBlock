--------------------------------------------------
-- 5. AUTO UPGRADE CARRY
--------------------------------------------------
Tabs.Auto:AddToggle("Carry", {
    Title = "Auto Upgrade Carry"
}):OnChanged(function(v)
    _G.Carry = v
    while _G.Carry do
        Event:FireServer("BuyCarryUpgrade")
        task.wait(0.5)
    end
end)

--------------------------------------------------
-- 6. LUCKY BLOCK FARM
--------------------------------------------------
local SelectedRarity = "Common"

Tabs.Auto:AddDropdown("Rarity", {
    Title = "Rarity",
    Values = {"Common","Uncommon","Rare","Epic","Legendary","Celestial"},
    Default = 1,
    Multi = false
}):OnChanged(function(v)
    SelectedRarity = v
end)

Tabs.Auto:AddToggle("LuckyFarm", {
    Title = "Auto Farm Lucky Block"
}):OnChanged(function(v)
    _G.LuckyFarm = v

    while _G.LuckyFarm do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local oldPos = root and root.CFrame

        for _,block in pairs(workspace.LuckyBlocks:GetChildren()) do
            if block:IsA("MeshPart") then
                local gui = block:FindFirstChild("LuckyBlockGUI")
                local prompt = block:FindFirstChildOfClass("ProximityPrompt")

                if gui and prompt then
                    local rarity = gui:FindFirstChild("Rarity")
                    if rarity and rarity.Text == SelectedRarity then
                        root.CFrame = block.CFrame
                        task.wait(0.2)
                        fireproximityprompt(prompt)
                        task.wait(0.2)
                        root.CFrame = oldPos
                    end
                end
            end
        end
        task.wait(1)
    end
end)

--------------------------------------------------
-- 7. REMOVE NPC
--------------------------------------------------
Tabs.Auto:AddButton({
    Title = "Remove NPC",
    Callback = function()
        while true do
            for _,v in pairs(workspace:GetChildren()) do
                if v.Name == "NPC" and v:IsA("Model") then
                    if v:FindFirstChild("Humanoid") or v:FindFirstChild("HumanoidRootPart") then
                        v:Destroy()
                    end
                end
            end
            task.wait(1)
        end
    end
})

