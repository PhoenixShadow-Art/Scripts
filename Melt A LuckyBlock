--------------------------------------------------
-- 6 LUCKY BLOCK FARM (FIXED)
--------------------------------------------------
local SelectedRarity = "Common"

Tabs.Auto:AddDropdown("Rarity", {
    Title="Rarity",
    Values={"Common","Uncommon","Rare","Epic","Legendary","Celestial"},
    Default=1
}):OnChanged(function(v)
    SelectedRarity = v
end)

Tabs.Auto:AddToggle("LuckyFarm", {Title="Auto Farm Lucky Block"}):OnChanged(function(v)
    State.LuckyFarm = v

    task.spawn(function()
        while State.LuckyFarm do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")

            if root then
                local old = root.CFrame

                for _,block in ipairs(workspace.LuckyBlocks:GetChildren()) do
                    if not State.LuckyFarm then break end

                    if block:IsA("MeshPart") then
                        local gui = block:FindFirstChild("LuckyBlockGUI")
                        local prompt = block:FindFirstChildOfClass("ProximityPrompt")

                        if gui and prompt then
                            local rarity = gui:FindFirstChild("Rarity")

                            if rarity and rarity.Text == SelectedRarity then
                                root.CFrame = block.CFrame + Vector3.new(0,3,0)
                                task.wait(0.25)

                                fireproximityprompt(prompt)

                                task.wait(0.25)

                                root.CFrame = old
                                break -- ONLY ONE TARGET
                            end
                        end
                    end
                end
            end

            task.wait(1)
        end
    end)
end)

