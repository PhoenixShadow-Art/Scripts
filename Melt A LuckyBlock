--------------------------------------------------
-- 3. AUTO BUY FLAMETHROWERS
--------------------------------------------------
local Flames = {
    "Iron","Steel","Emerald","Diamond","Golden","Obsidian",
    "Glacier","Lava","Storm","Shadow","Toxic","Plasma",
    "CryStal","Void","Celestial","Toy"
}

Toggles.Flamethrower = Tabs.Auto:AddToggle("Flame", {
    Title = "Auto Buy All Flamethrowers",
    Default = false
})

Toggles.Flamethrower:OnChanged(function(v)
    _G.Flame = v
    while _G.Flame do
        for _,name in pairs(Flames) do
