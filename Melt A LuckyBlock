--// Load Fluent UI
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

--// Remote
local Event = game:GetService("ReplicatedStorage").Framework.Remotes.Event

--// Window
local Window = Fluent:CreateWindow({
    Title = "Melt a Lucky Block",
    SubTitle = "by GrimSyndicate",
    TabWidth = 160,
    Size = UDim2.fromOffset(500, 375),
    Theme = "Dark"
})

--// Tabs
local Tabs = {
    Auto = Window:AddTab({ Title = "Auto", Icon = "" }),
    Credit = Window:AddTab({ Title = "Credit", Icon = "" })
}

--// CREDIT TAB
Tabs.Credit:AddParagraph({
    Title = "Creators",
    Content = "Marcus Vale\nDamien Crowe "
})

Tabs.Credit:AddParagraph({
    Title = "Description",
    Content = "Melt a Lucky Block Hub using Fluent UI. Made for automation & farming."
})

--// SECTION
local AutoFarm = Tabs.Auto:AddSection("Auto Farm")

--// STATES
local Toggles = {}

--------------------------------------------------
-- 1. AUTO COLLECT CASH
--------------------------------------------------
Toggles.AutoCash = Tabs.Auto:AddToggle("AutoCash", {
    Title = "Auto Collect Cash",
    Description = "Loops 1-20",
    Default = false
})

Toggles.AutoCash:OnChanged(function(v)
    _G.AutoCash = v
    while _G.AutoCash do
        for i = 1, 20 do
            Event:FireServer("ClaimSlotMoney", tostring(i))
        end
        task.wait(0.1)
    end
end)

--------------------------------------------------
-- 2. AUTO UPGRADE BRAINROT
--------------------------------------------------
Toggles.Brainrot = Tabs.Auto:AddToggle("Brainrot", {
    Title = "Auto Upgrade Brainrot",
    Default = false
})

Toggles.Brainrot:OnChanged(function(v)
    _G.Brainrot = v
    while _G.Brainrot do
        for i = 1, 20 do
