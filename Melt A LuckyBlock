--[[ MAIN LOOP ]]--
RunService.Heartbeat:Connect(function()
    -- 1. Auto Collect Cash
    if Toggles.AutoCollectCash then
        for i = 1, 20 do
            pcall(function()
                Event:FireServer("ClaimSlotMoney", tostring(i))
            end)
        end
    end
    
    -- 2. Auto Upgrade Brainrot
    if Toggles.AutoUpgradeBrainrot then
        for i = 1, 20 do
            pcall(function()
                Event:FireServer("UpgradeSlotBrainrot", tostring(i))
            end)
        end
    end
    
    -- 3. Auto Buy Flamethrowers
    if Toggles.AutoBuyFlamethrowers then
        local flamethrowers = {"Iron", "Steel", "Emerald", "Diamond", "Golden", "Obsidian", 
                               "Glacier", "Lava", "Storm", "Shadow", "Toxic", "Plasma", 
                               "Crystal", "Void", "Celestial", "Toy"}
        for _, flamethrower in ipairs(flamethrowers) do
            pcall(function()
                Event:FireServer("FlamethrowerAction", flamethrower)
            end)
        end
    end
    
    -- 4. Auto Claim Playtime Rewards
    if Toggles.AutoClaimPlaytime then
        for i = 1, 6 do
            pcall(function()
                Event:FireServer("ClaimPlaytimeReward", i)
            end)
        end
    end
    
    -- 5. Auto Upgrade Carry
    if Toggles.AutoUpgradeCarry then
        pcall(function()
            Event:FireServer("BuyCarryUpgrade")
        end)
    end
    
    -- 6. Auto Farm Lucky Block (One block at a time)
    if Toggles.AutoFarmLuckyBlock and next(SelectedRarities) and not CurrentlyFarming then
        CurrentlyFarming = true
        
        task.spawn(function()
            local character = Player.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local hrp = character.HumanoidRootPart
                local luckyBlocksFolder = Workspace:FindFirstChild("LuckyBlocks")
                
                if luckyBlocksFolder then
                    -- Save current position before teleporting
                    local savedPosition = hrp.CFrame
                    
                    -- Find a valid lucky block to farm
                    local blockToFarm = nil
                    
                    for _, block in pairs(luckyBlocksFolder:GetChildren()) do
                        if block:IsA("MeshPart") and block ~= LastFarmedBlock then
                            local proximityPrompt = block:FindFirstChildOfClass("ProximityPrompt")
                            local luckyBlockGUI = block:FindFirstChild("LuckyBlockGUI")
                            
                            if proximityPrompt and luckyBlockGUI then
                                local rarityLabel = luckyBlockGUI:FindFirstChild("Rarity")
                                
                                if rarityLabel and rarityLabel:IsA("TextLabel") then
                                    local rarity = rarityLabel:GetAttribute("Rarity") or rarityLabel.Text
                                    
                                    -- Check if this rarity is selected
                                    if SelectedRarities[rarity] then
                                        blockToFarm = block
                                        break
                                    end
                                end
                            end
                        end
                    end
                    
                    -- If we found a block, teleport and farm it
                    if blockToFarm then
                        LastFarmedBlock = blockToFarm
                        
                        -- Teleport to the block
                        pcall(function()
                            hrp.CFrame = blockToFarm.CFrame + Vector3.new(0, 3, 0)
                        end)
                        
                        task.wait(0.2)
                        
                        -- Fire proximity prompt
                        local proximityPrompt = blockToFarm:FindFirstChildOfClass("ProximityPrompt")
                        if proximityPrompt then
                            pcall(function()
                                fireproximityprompt(proximityPrompt)
                            end)
                        end
                        
                        task.wait(0.3)
                        
                        -- Teleport back to saved position
                        pcall(function()
                            hrp.CFrame = savedPosition
                        end)
                        
                        task.wait(0.1)
                    else
                        -- Reset last farmed block if no valid blocks found
                        LastFarmedBlock = nil
                    end
                end
            end
            
            CurrentlyFarming = false
        end)
    end
    
    -- 8. Auto Rebirth
    if Toggles.AutoRebirth then
        pcall(function()
            Event:FireServer("Rebirth")
        end)
    end
    
    -- 10. Auto Buy Speed Upgrade
    if Toggles.AutoBuySpeed then
        pcall(function()
            Event:FireServer("BuySpeedUpgrade")
        end)
    end
end)

