-- Function to send webhook notification
local function SendWebhookNotification(blockName, rarity, position)
    if not Toggles.WebhookNotifications or WebhookURL == "" then
        return
    end
    
    -- Check if we already notified about this block
    local blockKey = tostring(blockName) .. "_" .. tostring(rarity)
    if NotifiedBlocks[blockKey] then
        return
    end
    
    NotifiedBlocks[blockKey] = true
    
    -- Determine color based on rarity
    local rarityColors = {
        ["Common"] = 9807270,      -- Gray
        ["Uncommon"] = 3066993,    -- Green
        ["Rare"] = 3447003,        -- Blue
        ["Epic"] = 10181046,       -- Purple
        ["Legendary"] = 15844367,  -- Gold
        ["Celestial"] = 15844367,  -- Gold/Yellow
        ["Secret"] = 16711680      -- Red
    }
    
    local color = rarityColors[rarity] or 3447003
    
    -- Determine emoji based on rarity
    local rarityEmojis = {
        ["Common"] = "⚪",
        ["Uncommon"] = "🟢",
        ["Rare"] = "🔵",
        ["Epic"] = "🟣",
        ["Legendary"] = "🟡",
        ["Celestial"] = "⭐",
        ["Secret"] = "🔴"
    }
    
    local emoji = rarityEmojis[rarity] or "📦"
    
    pcall(function()
        local data = {
            ["content"] = "",
            ["embeds"] = {{
                ["title"] = emoji .. " Lucky Block Spawned!",
                ["description"] = "A lucky block has appeared in the game!",
                ["color"] = color,
                ["fields"] = {
                    {
                        ["name"] = "🎁 Block Type",
                        ["value"] = blockName or "Unknown",
                        ["inline"] = true
                    },
                    {
                        ["name"] = "💎 Rarity",
                        ["value"] = rarity or "Unknown",
                        ["inline"] = true
                    },
                    {
                        ["name"] = "👤 Player",
                        ["value"] = Player.Name,
                        ["inline"] = true
                    },
                    {
                        ["name"] = "📍 Position",
                        ["value"] = position and string.format("X: %.1f, Y: %.1f, Z: %.1f", position.X, position.Y, position.Z) or "Unknown",
                        ["inline"] = false
                    }
                },
                ["footer"] = {
                    ["text"] = "Melt a Lucky Block by GrimSyndicate"
                },
                ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%S")
            }}
        }
        
        request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(data)
        })
    end)
end

